# secrets.env — INTENTIONALLY FAKE secrets file
#
# This file simulates the kind of credentials a developer might accidentally
# leave in their project directory. It is excluded from the Docker build context
# by the .dockerignore file in this module.
#
# ── WHY THIS FILE EXISTS ─────────────────────────────────────────────────────
# In real projects, developers often keep .env files in their project root for
# local development convenience (loaded by tools like python-dotenv or direnv).
# Without a .dockerignore, `docker build` would send this file to the daemon
# and it could end up baked into the image layers — readable by anyone who
# pulls or inspects the image.
#
# ── WHAT WOULD HAPPEN WITHOUT .dockerignore ──────────────────────────────────
# Without excluding this file:
#   1. It gets bundled into the build context tar archive.
#   2. If a COPY . . instruction is used, it lands inside the image.
#   3. Anyone running `docker run` can `cat /app/secrets.env` and read it.
#   4. Even if COPY . . is not used, the file was still SENT to the daemon —
#      and could appear in build logs or intermediate layer caches.
#
# ── ALL VALUES HERE ARE FAKE ─────────────────────────────────────────────────
# Never commit real credentials to version control.

DATABASE_URL=postgresql://fakeuser:fakepassword@db.example.com:5432/fakedb
API_KEY=sk-fake-key-1234567890abcdef
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
JWT_SECRET=this-is-a-fake-jwt-secret-do-not-use
STRIPE_SECRET_KEY=sk_test_fake_stripe_key_placeholder
